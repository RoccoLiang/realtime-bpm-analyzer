{
  "name": "realtime-bpm-analyzer",
  "version": "5.0.1",
  "description": "Real-time BPM and Musical Key detection library for Web Audio API",
  "author": {
    "name": "David Lepaux",
    "email": "d.lepaux@gmail.com",
    "url": "https://github.com/RoccoLiang"
  },
  "keywords": [
    "webaudioapi",
    "audiobuffer",
    "audio",
    "stream",
    "microphone",
    "realtime",
    "no-dependency",
    "tempo",
    "bpm",
    "beats",
    "analyzer",
    "musical-key",
    "key-detection",
    "chromagram"
  ],
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./processor": {
      "types": "./dist/realtime-bpm-processor.d.ts",
      "default": "./dist/realtime-bpm-processor.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "readme.md",
    "license.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "cd examples/03-vanilla-microphone && npm run dev",
    "build": "bash bin/build/library.sh",
    "lint": "xo",
    "lint:fix": "xo --fix",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RoccoLiang/realtime-bpm-analyzer.git"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.5.0",
    "@commitlint/config-conventional": "^18.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "esbuild": "^0.27.3",
    "husky": "^8.0.3",
    "semantic-release": "^25.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "xo": "^0.56.0"
  },
  "xo": {
    "space": 2,
    "semicolon": true,
    "ignores": [
      "examples/**",
      "build.ts"
    ],
    "globals": [
      "process",
      "document",
      "navigator",
      "window"
    ],
    "rules": {
      "n/prefer-global/process": "off",
      "node/prefer-global/process": 0,
      "no-await-in-loop": "off",
      "jsdoc/tag-lines": "off",
      "import/no-unassigned-import": "off",
      "import/no-anonymous-default-export": "off",
      "import/extensions": "off",
      "unicorn/no-array-reduce": "off",
      "unicorn/numeric-separators-style": "off",
      "unicorn/prefer-top-level-await": "off",
      "unicorn/prefer-add-event-listener": "off",
      "@typescript-eslint/triple-slash-reference": "off",
      "@typescript-eslint/no-loss-of-precision": "off",
      "@typescript-eslint/no-unused-expressions": "off",
      "no-promise-executor-return": "off",
      "@typescript-eslint/no-empty-function": "off",
      "unicorn/prevent-abbreviations": "off"
    }
  },
  "lint-staged": {
    "**/*": "xo --fix"
  }
}
